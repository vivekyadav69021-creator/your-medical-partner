
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, matches Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "description": "The date and time the user profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "Doctor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Doctor",
      "type": "object",
      "description": "Represents a doctor available for consultation.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Doctor entity."
        },
        "name": {
          "type": "string",
          "description": "The doctor's full name."
        },
        "specialty": {
          "type": "string",
          "description": "The doctor's medical specialty."
        },
        "location": {
          "type": "string",
          "description": "The doctor's location (e.g., city, country)."
        },
        "isIndianDoctor": {
          "type": "boolean",
          "description": "Indicates if the doctor is an Indian Doctor or not."
        }
      },
      "required": [
        "id",
        "name",
        "specialty"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment with a doctor.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Appointment entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:N Appointment)"
        },
        "doctorId": {
          "type": "string",
          "description": "Reference to Doctor. (Relationship: Doctor 1:N Appointment)"
        },
        "dateTime": {
          "type": "string",
          "description": "The date and time of the appointment.",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes for the appointment."
        }
      },
      "required": [
        "id",
        "userId",
        "doctorId",
        "dateTime"
      ]
    },
    "Medicine": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Medicine",
      "type": "object",
      "description": "Represents a medicine available in the medical store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Medicine entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the medicine."
        },
        "description": {
          "type": "string",
          "description": "A description of the medicine."
        },
        "category": {
          "type": "string",
          "description": "The category of the medicine."
        },
        "price": {
          "type": "number",
          "description": "The price of the medicine."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "category",
        "price"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents an order placed for medicines.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:N Order)"
        },
        "medicineIds": {
          "type": "array",
          "description": "References to Medicines. (Relationship: Order 1:N Medicine)",
          "items": {
            "type": "string"
          }
        },
        "orderDate": {
          "type": "string",
          "description": "The date the order was placed.",
          "format": "date-time"
        },
        "totalAmount": {
          "type": "number",
          "description": "The total amount of the order."
        }
      },
      "required": [
        "id",
        "userId",
        "medicineIds",
        "orderDate",
        "totalAmount"
      ]
    },
    "HealthScore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HealthScore",
      "type": "object",
      "description": "Represents a user's health score.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the HealthScore entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:1 HealthScore)"
        },
        "score": {
          "type": "number",
          "description": "The user's health score."
        },
        "lastUpdated": {
          "type": "string",
          "description": "The date and time the score was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "score",
        "lastUpdated"
      ]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile information. Since auth is removed, this is not used.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier for the user."
            }
          ]
        }
      },
      {
        "path": "/doctors/{doctorId}",
        "definition": {
          "entityName": "Doctor",
          "schema": {
            "$ref": "#/backend/entities/Doctor"
          },
          "description": "Stores doctor information. Accessible to all users.",
          "params": [
            {
              "name": "doctorId",
              "description": "The unique identifier for the doctor."
            }
          ]
        }
      },
      {
        "path": "/medicines/{medicineId}",
        "definition": {
          "entityName": "Medicine",
          "schema": {
            "$ref": "#/backend/entities/Medicine"
          },
          "description": "Stores medicine information. Accessible to all users.",
          "params": [
            {
              "name": "medicineId",
              "description": "The unique identifier for the medicine."
            }
          ]
        }
      }
    ],
    "reasoning": "With authentication removed, the data structure is simplified. User-specific collections like appointments, orders, and health scores are no longer relevant as there's no concept of a logged-in user. The remaining public collections for doctors and medicines are kept as they are globally accessible."
  }
}

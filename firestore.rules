/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model. All private user data,
 * including profiles, appointments, and orders, is nested under a path specific to that user's ID
 * (e.g., /users/{userId}/...). This ensures that users can only access their own information.
 *
 * Data Structure: The data is organized into three main top-level collections:
 * 1. /users: Contains all user-specific data in subcollections. The root /users collection itself is not listable.
 * 2. /doctors: A public, read-only collection of doctor profiles browsable by any user.
 * 3. /medicines: A public, read-only collection of available medicines browsable by any user.
 *
 * Key Security Decisions:
 * - User Privacy: Listing the entire /users collection is explicitly disallowed to prevent user enumeration.
 * - Ownership Enforcement: All write operations on user-owned data are restricted to the authenticated document owner.
 * - Relational Integrity: On creation, documents within a user's data tree (e.g., an order) must contain a 'userId'
 *   field that matches the user ID in the path, ensuring data consistency. This 'userId' field is immutable.
 * - Public Data: The /doctors and /medicines collections are publicly readable to allow for browsing within the app,
 *   but are locked down against all client-side writes. It is assumed this data is managed by a trusted backend or admin.
 *
 * Denormalization for Authorization: The structure inherently uses denormalization by scoping all private data under
 * a user-specific path. This makes authorization checks simple and performant, as rules can check ownership
 * directly from the path (`isOwner(userId)`) without needing any costly `get()` calls to other documents.
 *
 * Structural Segregation: The design clearly separates private user data (/users) from public, browsable data
 * (/doctors, /medicines). This is a secure and performant pattern that avoids complex filtering rules and ensures
 * that queries for public data cannot accidentally expose private information.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A robust check for update/delete operations. It ensures the user is the
     * owner AND the document they are trying to modify actually exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // ------------------------------------------------------------------------
    // User Data Collections
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to a user's root profile document and all nested private data.
     * @path        /users/{userId}
     * @allow       A user with uid 'user-abc' (create)s their own profile at /users/user-abc.
     * @deny        A user with uid 'user-xyz' (get)s the profile at /users/user-abc.
     * @principle   Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      // A user can read their own profile, but cannot list all users.
      allow get: if isOwner(userId);
      allow list: if false;

      // A user can create their own profile.
      // The document's internal 'id' must match the user's auth UID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // The owner can update their profile. The internal 'id' cannot be changed.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      // The owner can delete their profile document.
      allow delete: if isExistingOwner(userId);

      /**
       * @description User's private appointments.
       * @path        /users/{userId}/appointments/{appointmentId}
       * @allow       A user with uid 'user-abc' (create)s an appointment at /users/user-abc/appointments/appt-123.
       * @deny        A user with uid 'user-xyz' (list)s appointments under /users/user-abc.
       * @principle   Enforces document ownership for all CRUD operations within a user's private subcollection.
       */
      match /appointments/{appointmentId} {
        // Owner can read their own appointments.
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);

        // Owner can create an appointment. The appointment data must be linked to them.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;

        // Owner can update an existing appointment. The userId link cannot be changed.
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;

        // Owner can delete their existing appointment.
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User's private medicine orders.
       * @path        /users/{userId}/orders/{orderId}
       * @allow       A user with uid 'user-abc' (get)s their order at /users/user-abc/orders/order-456.
       * @deny        A user with uid 'user-xyz' (delete)s the order at /users/user-abc/orders/order-456.
       * @principle   Enforces document ownership for all CRUD operations within a user's private subcollection.
       */
      match /orders/{orderId} {
        // Owner can read their own orders.
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);

        // Owner can create an order. The order data must be linked to them.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;

        // Owner can update an existing order. The userId link cannot be changed.
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;

        // Owner can delete their existing order.
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description A user's single health score document.
       * @path        /users/{userId}/healthScore
       * @allow       A user with uid 'user-abc' (update)s their health score at /users/user-abc/healthScore.
       * @deny        A user with uid 'user-xyz' (get)s the document at /users/user-abc/healthScore.
       * @principle   Enforces ownership on a specific, named document within a user's data tree.
       */
      match /healthScore {
        // This is a single document, so list is not a valid operation.
        allow get: if isOwner(userId);
        allow list: if false;

        // Owner can create their health score. The data must be linked to them.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;

        // Owner can update their existing score. The userId link cannot be changed.
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;

        // Owner can delete their existing score.
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User's private smartwatch data.
       * @path        /users/{userId}/smartwatchData/{smartwatchId}
       * @allow       A user with uid 'user-abc' (create)s a data entry at /users/user-abc/smartwatchData/data-789.
       * @deny        A user with uid 'user-xyz' (list)s data under /users/user-abc/smartwatchData.
       * @principle   Enforces document ownership for all CRUD operations within a user's private subcollection.
       */
      match /smartwatchData/{smartwatchId} {
        // Owner can read their own smartwatch data.
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);

        // Owner can create a data entry. The data must be linked to them.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;

        // Owner can update an existing entry. The userId link cannot be changed.
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;

        // Owner can delete an existing entry.
        allow delete: if isExistingOwner(userId);
      }
    }

    // ------------------------------------------------------------------------
    // Public Read-Only Collections
    // ------------------------------------------------------------------------

    /**
     * @description Stores information about doctors. This data is public for anyone to read.
     * @path        /doctors/{doctorId}
     * @allow       Any user, signed in or not, (get)s or (list)s doctor profiles.
     * @deny        Any client (create)s, (update)s, or (delete)s a doctor profile.
     * @principle   Secures a collection as publicly readable but prevents all client-side modification.
     */
    match /doctors/{doctorId} {
      // Anyone can view doctor profiles.
      allow get: if true;
      allow list: if true;

      // No client can write to the doctors collection. Managed by admins/backend only.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores information about medicines. This data is public for anyone to read.
     * @path        /medicines/{medicineId}
     * @allow       Any user, signed in or not, (get)s or (list)s medicine details.
     * @deny        Any client (create)s, (update)s, or (delete)s a medicine.
     * @principle   Secures a collection as publicly readable but prevents all client-side modification.
     */
    match /medicines/{medicineId} {
      // Anyone can view medicine details.
      allow get: if true;
      allow list: if true;

      // No client can write to the medicines collection. Managed by admins/backend only.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
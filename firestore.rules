rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: This ruleset enforces a strict user-ownership model.
     * All sensitive user data, including profiles, appointments, orders, and
     * health scores, is private and can only be accessed by the authenticated
     * owner of that data. Publicly accessible data, like lists of doctors
     * and medicines, is stored in separate top-level collections and is made
     * read-only for all clients, ensuring this catalog data is managed by a
     * trusted backend environment.
     *
     * Data Structure: User-specific data is hierarchically organized under the
     * `/users/{userId}` path. This structure provides a clear and secure boundary
     * for each user's information. Public data catalogs, such as `/doctors` and
     * `/medicines`, exist at the root level for global read access.
     *
     * Key Security Decisions:
     * - Default Deny: All paths are closed by default. Access must be granted explicitly.
     * - No User Enumeration: The root `/users` collection is not listable,
     *   preventing malicious actors from discovering the user base.
     * - Write Protection on Public Data: All client-side write operations
     *   on public collections (`/doctors`, `/medicines`) are disabled. This data
     *   should be managed via the Firebase Admin SDK in a secure environment.
     * - Relational Integrity: On creation, documents in user subcollections
     *   must contain a `userId` field that matches the authenticated user's ID,
     *   enforcing data consistency and ownership at the point of creation.
     *
     * Denormalization for Authorization: The rules rely on denormalized `userId`
     * fields within documents like appointments and orders. For example, an
     * appointment at `/users/USER_A/appointments/APP_1` must contain the field
     * `{ userId: "USER_A" }`. This avoids costly and slow `get()` calls to parent
     * documents and enables simpler, more performant security rules.
     *
     * Structural Segregation: Private user data (e.g., `/users/{userId}/orders`)
     * and public data (e.g., `/medicines`) are stored in separate collections.
     * This clean separation ensures that list operations are secure and efficient,
     * as rules do not need to filter results based on individual document fields.
     */

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that a user is creating their own profile document and that
     * the document's internal 'id' field matches their user ID.
     */
    function isCreatingOwnProfile(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the profile 'id' field during an update.
     */
    function isProfileIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that a new document contains a 'userId' field matching the
     * authenticated user's ID. Enforces relational integrity on create.
     */
    function hasCorrectUserIdOnCreate(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    /**
     * Enforces immutability of the 'userId' field during an update to prevent
     * re-assigning ownership of a document.
     */
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // -------------------------------------------------------------------------
    // User Profile Rules
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own profile document for the first time.
     * @deny (list) Any user attempting to list all user profiles to prevent user enumeration.
     * @principle Restricts access to a user's own data tree and allows self-creation of a profile.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnProfile(userId);
      allow update: if isExistingOwner(userId) && isProfileIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    // -------------------------------------------------------------------------
    // User Sub-collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to a user's private appointment records.
     * @path /users/{userId}/appointments/{appointmentId}
     * @allow (create) An authenticated user creating an appointment for themselves.
     * @deny (get) User 'B' trying to read an appointment belonging to user 'A'.
     * @principle Enforces strict document ownership within a user's private data subcollection.
     */
    match /users/{userId}/appointments/{appointmentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if hasCorrectUserIdOnCreate(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to a user's private order history.
     * @path /users/{userId}/orders/{orderId}
     * @allow (list) An authenticated user listing their own past orders.
     * @deny (create) User 'B' trying to create an order on behalf of user 'A'.
     * @principle Enforces strict document ownership within a user's private data subcollection.
     */
    match /users/{userId}/orders/{orderId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if hasCorrectUserIdOnCreate(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to a user's private health score record.
     * @path /users/{userId}/healthScore/{scoreId}
     * @allow (update) An authenticated user updating their own health score.
     * @deny (get) Any unauthenticated user trying to read a health score.
     * @principle Enforces strict document ownership for a sensitive 1-to-1 user data record.
     */
    match /users/{userId}/healthScore/{scoreId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if hasCorrectUserIdOnCreate(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    // -------------------------------------------------------------------------
    // Public Read-Only Collections
    // -------------------------------------------------------------------------

    /**
     * @description Provides public, read-only access to the list of doctors.
     * @path /doctors/{doctorId}
     * @allow (get, list) Any user, authenticated or not, reading doctor profiles.
     * @deny (create, update, delete) Any client trying to modify the doctor list.
     * @principle Secures public catalog data by making it read-only for clients. Writes must be performed by a trusted admin backend.
     */
    match /doctors/{doctorId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Provides public, read-only access to the list of medicines.
     * @path /medicines/{medicineId}
     * @allow (get, list) Any user, authenticated or not, reading medicine information.
     * @deny (create, update, delete) Any client trying to modify the medicine catalog.
     * @principle Secures public catalog data by making it read-only for clients. Writes must be performed by a trusted admin backend.
     */
    match /medicines/{medicineId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}